<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Question for Subhro ❤️</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    font-family:Arial,sans-serif;
    overflow:hidden;
}

.container{
    background:white;
    width:90%;
    max-width:500px;
    padding:30px;
    border-radius:25px;
    text-align:center;
    box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

h1{
    color:#ff4d79;
}

p{
    font-size:18px;
    color:#555;
}

.ball{
    font-size:70px;
    animation:bounce 1s infinite;
}

@keyframes bounce{
    50%{transform:translateY(-12px);}
}

.btns{
    margin-top:25px;
    position:relative;
    height:120px;
}

button{
    border:none;
    padding:14px 28px;
    border-radius:50px;
    font-size:18px;
    cursor:pointer;
}

#yes{
    background:#ff4d79;
    color:white;
}

#no{
    background:#ddd;
    position:absolute;
    left:60%;
}

#result{
    display:none;
}

.hearts{
    position:fixed;
    font-size:24px;
    animation:float 3s linear forwards;
}

@keyframes float{
    from{
        transform:translateY(0);
        opacity:1;
    }
    to{
        transform:translateY(-500px);
        opacity:0;
    }
}
</style>

</head>

<body>

<div class="container">

<div class="ball">⚽🇵🇹</div>

<h1>Hey Subhro ❤️</h1>

<p>
Will you watch Portugal's World Cup match with me? 🥺<br><br>
There will be snacks 🍿, excitement ⚽,<br>
and a very cute girl waiting for you ❤️
</p>

<div class="btns">
<button id="yes">YES ❤️</button>
<button id="no">NO 😭</button>
</div>

<div id="result">
<h1>YAYYYYYY!!! 🎉❤️</h1>
<p>
It's a date! ⚽🇵🇹<br><br>
Portugal + You + Me = Perfect Evening ✨
</p>
<h2>🥰🥰🥰</h2>
</div>

</div>

<script>

const noBtn = document.getElementById("no");

noBtn.addEventListener("mouseenter", () => {
    const x = Math.random() * (window.innerWidth - 100);
    const y = Math.random() * (window.innerHeight - 60);

    noBtn.style.position = "fixed";
    noBtn.style.left = x + "px";
    noBtn.style.top = y + "px";
});

document.getElementById("yes").onclick = () => {

    document.querySelector(".btns").style.display = "none";
    document.getElementById("result").style.display = "block";

    setInterval(() => {

        const heart = document.createElement("div");
        heart.className = "hearts";
        heart.innerHTML = "❤️";

        heart.style.left = Math.random() * window.innerWidth + "px";
        heart.style.top = window.innerHeight + "px";

        document.body.appendChild(heart);

        setTimeout(() => heart.remove(), 3000);

    }, 150);

};

</script>

</body>
</html>
